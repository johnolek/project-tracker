{
  "comment": "Shared filter-semantics cases (PROJ-79). Exercised by BOTH spec/javascript/item_filters.test.js (matchesFilters in app/javascript/item_filters.js) and the Ruby spec of ComparisonsController#matches_filters? so the two implementations cannot drift silently. Covers the mirrored core: item_type, min/max points (including the unpointed-item rules), tag AND-matching, and tag exclusion (PROJ-69: any excluded tag present rejects).",
  "cases": [
    { "name": "no filters passes everything",
      "item": { "item_type": "bug", "points": null, "tags": [] },
      "filters": {}, "expected": true },
    { "name": "type filter matches exactly",
      "item": { "item_type": "bug", "points": 1, "tags": [] },
      "filters": { "item_type": "bug" }, "expected": true },
    { "name": "type filter rejects other types",
      "item": { "item_type": "feature", "points": 1, "tags": [] },
      "filters": { "item_type": "bug" }, "expected": false },
    { "name": "min excludes an unpointed item",
      "item": { "item_type": "bug", "points": null, "tags": [] },
      "filters": { "min_points": 1 }, "expected": false },
    { "name": "min excludes a smaller estimate",
      "item": { "item_type": "bug", "points": 2, "tags": [] },
      "filters": { "min_points": 3 }, "expected": false },
    { "name": "min passes an equal estimate",
      "item": { "item_type": "bug", "points": 3, "tags": [] },
      "filters": { "min_points": 3 }, "expected": true },
    { "name": "max passes an unpointed item",
      "item": { "item_type": "bug", "points": null, "tags": [] },
      "filters": { "max_points": 2 }, "expected": true },
    { "name": "max excludes a larger estimate",
      "item": { "item_type": "bug", "points": 5, "tags": [] },
      "filters": { "max_points": 2 }, "expected": false },
    { "name": "max passes an equal estimate",
      "item": { "item_type": "bug", "points": 2, "tags": [] },
      "filters": { "max_points": 2 }, "expected": true },
    { "name": "single tag must be present",
      "item": { "item_type": "bug", "points": 1, "tags": ["api"] },
      "filters": { "tags": ["api"] }, "expected": true },
    { "name": "single tag missing fails",
      "item": { "item_type": "bug", "points": 1, "tags": ["ui"] },
      "filters": { "tags": ["api"] }, "expected": false },
    { "name": "multiple tags AND together",
      "item": { "item_type": "bug", "points": 1, "tags": ["api", "ui"] },
      "filters": { "tags": ["api", "ui"] }, "expected": true },
    { "name": "partial tag overlap fails",
      "item": { "item_type": "bug", "points": 1, "tags": ["api"] },
      "filters": { "tags": ["api", "ui"] }, "expected": false },
    { "name": "all criteria compose with AND",
      "item": { "item_type": "bug", "points": 3, "tags": ["api", "ui"] },
      "filters": { "item_type": "bug", "min_points": 2, "max_points": 5, "tags": ["api"] }, "expected": true },
    { "name": "one failing criterion rejects despite the rest passing",
      "item": { "item_type": "bug", "points": 3, "tags": ["api"] },
      "filters": { "item_type": "bug", "min_points": 2, "tags": ["ui"] }, "expected": false },
    { "name": "excluded tag rejects an item carrying it",
      "item": { "item_type": "bug", "points": 1, "tags": ["ui"] },
      "filters": { "exclude_tags": ["ui"] }, "expected": false },
    { "name": "excluded tag passes an item without it",
      "item": { "item_type": "bug", "points": 1, "tags": ["api"] },
      "filters": { "exclude_tags": ["ui"] }, "expected": true },
    { "name": "include and exclude compose with AND",
      "item": { "item_type": "bug", "points": 1, "tags": ["api", "ui"] },
      "filters": { "tags": ["api"], "exclude_tags": ["ui"] }, "expected": false }
  ]
}
