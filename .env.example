# Example environment for a production deploy (Coolify → Environment Variables).
# Copy to .env for local prod-like runs, or set these in your host's env UI.
# .env itself is gitignored; this .example file is the tracked reference.
#
# Only the "Required" blocks are needed to boot and use the app. Email needs
# one delivery block (API or SMTP) plus the addressing block. Everything under
# "Runtime tuning" has sane Docker defaults and can be omitted.

# ─── Required: core ──────────────────────────────────────────────────────────
# PostgreSQL connection string.
DATABASE_URL=postgres://user:password@host:5432/project_tracker_production
# Decrypts config/credentials.yml.enc. From config/master.key (never commit it).
RAILS_MASTER_KEY=

# Self-registration is CLOSED in production by default (single-user app).
# Set to true temporarily if you ever need to create another account.
# ALLOW_SIGNUPS=false

# ─── Required: passkeys / WebAuthn ───────────────────────────────────────────
# RP ID is the registrable domain (no scheme, no port). ORIGIN is the full URL
# the app is served from. These must match the site or passkeys won't validate.
WEBAUTHN_RP_ID=tracker.example.com
WEBAUTHN_ORIGIN=https://tracker.example.com
# Shown in the OS passkey prompt. Optional; defaults to "Project Tracker".
# WEBAUTHN_RP_NAME=Project Tracker

# ─── Email: delivery ─────────────────────────────────────────────────────────
# Pick ONE path.
#
# Preferred — SMTP2GO HTTP API. When set, mail goes over HTTPS and each send is
# logged as success (with email_id) or failure. Create the key in SMTP2GO under
# Settings → API Keys (format: api-...).
SMTP2GO_API_KEY=

# Fallback — SMTP. Used only when SMTP2GO_API_KEY is blank. With SMTP, a failed
# send is silent in production (raise_delivery_errors is off).
# SMTP_ADDRESS=mail.smtp2go.com
# SMTP_USERNAME=project_tracker
# SMTP_PASSWORD=
# SMTP_PORT=2525            # default 587
# SMTP_AUTHENTICATION=plain # default plain
# SMTP_DOMAIN=              # HELO domain; usually optional

# ─── Email: addressing ───────────────────────────────────────────────────────
# From address for sign-in / verification / recovery mail. MUST be a sender your
# provider has verified (SMTP2GO rejects unverified domains).
MAIL_FROM=john@johnoleksowicz.com
# Host used to build links inside emails. Optional; falls back to the
# WEBAUTHN_ORIGIN host when unset.
# MAIL_HOST=tracker.example.com

# ─── Runtime tuning (optional; Docker sets sensible defaults) ─────────────────
# WEB_CONCURRENCY=2         # Puma worker processes
# RAILS_MAX_THREADS=3       # threads per worker (also the DB pool size)
# JOB_CONCURRENCY=1         # Solid Queue worker threads
# SOLID_QUEUE_IN_PUMA=1     # run Solid Queue inside Puma (set by the Dockerfile)
# RAILS_LOG_LEVEL=info
# PORT=3000

# ─── Development only ─────────────────────────────────────────────────────────
# Target user for `bin/rails db:seed` (else the oldest user with a passkey).
# SEED_USER=
