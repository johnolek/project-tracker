<% content_for :title, "Prioritize · #{@project.name}" %>
<div class="level is-mobile">
  <div class="level-left">
    <div>
      <h1 class="title mb-1">Which matters more?</h1>
      <p class="subtitle is-6 has-text-weak"><%= link_to @project.name, project_path(@project) %></p>
    </div>
  </div>
  <div class="level-right"><%= link_to "View priorities", priorities_project_path(@project), class: "button" %></div>
</div>

<% if @pair %>
  <% item_a, item_b = @pair %>
  <div class="columns comparison-pair">
    <% { item_a => "a_wins", item_b => "b_wins" }.each do |item, outcome| %>
      <div class="column">
        <%= button_to project_comparisons_path(@project),
              params: { item_a_id: item_a.id, item_b_id: item_b.id, outcome: outcome },
              class: "comparison-card" do %>
          <span class="title is-5 is-block mb-2"><%= item.title %></span>
          <span class="tags mb-2">
            <span class="tag"><%= item.item_type %></span>
            <% if item.points %><span class="tag">Points: <%= item.points %></span><% end %>
          </span>
          <% notes = item.notes.to_plain_text %>
          <% if notes.present? %>
            <span class="is-block has-text-weak"><%= truncate(notes, length: 160) %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="buttons is-centered">
    <%= button_to "Equal priority", project_comparisons_path(@project),
          params: { item_a_id: item_a.id, item_b_id: item_b.id, outcome: "draw" },
          class: "button" %>
    <%= link_to "Skip", prioritize_project_path(@project), class: "button is-light" %>
  </div>

  <p class="has-text-centered has-text-weak"><%= pluralize(@comparison_count, "comparison") %> recorded so far.</p>
<% else %>
  <div class="notification is-info is-light">
    <p>You need at least two open items in this project to prioritize. Add or reopen some items, then come back.</p>
  </div>
<% end %>
