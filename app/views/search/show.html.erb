<% content_for :title, "Search" %>
<h1 class="title">Search</h1>

<%= form_with url: search_path, method: :get, data: { turbo_frame: "_top" } do |form| %>
  <div class="field has-addons">
    <div class="control is-expanded">
      <%= form.search_field :q, value: @query, placeholder: "Search projects and items…",
            class: "input", autofocus: true %>
    </div>
    <div class="control">
      <%= form.submit "Search", class: "button is-primary" %>
    </div>
  </div>
<% end %>

<% if @query.blank? %>
  <p class="has-text-weak mt-4">Enter a search term to find projects and items by name.</p>
<% elsif @projects.empty? && @items.empty? %>
  <p class="has-text-weak mt-4">Nothing matches &ldquo;<%= @query %>&rdquo;.</p>
<% end %>

<% if @projects.any? %>
  <h2 class="title is-5 mt-4">Projects</h2>
  <ul>
    <% @projects.each do |project| %>
      <li class="mb-1"><%= link_to project.name, project_path(project) %></li>
    <% end %>
  </ul>
<% end %>

<% if @items.any? %>
  <h2 class="title is-5 mt-4">Items</h2>
  <p class="has-text-weak">
    <%= pluralize(@items.size, "item") %> matching &ldquo;<%= @query %>&rdquo;.
  </p>

  <div class="table-container">
    <table class="table is-fullwidth is-striped is-hoverable">
      <thead>
        <tr><th>Title</th><th>Project</th><th>Type</th><th>Status</th><th>Points</th><th>Tags</th></tr>
      </thead>
      <tbody>
        <% @items.each do |item| %>
          <tr>
            <td><%= link_to item.title, project_item_path(item.project, item) %></td>
            <td><%= link_to item.project.name, project_path(item.project) %></td>
            <td><%= item_type_tag(item) %></td>
            <td><%= item.status.name %></td>
            <td><%= item.points %></td>
            <td>
              <div class="tags">
                <% item.tags.each do |tag| %>
                  <span class="tag is-small <%= tag_color_class(name: tag.name) %>"><%= tag.name %></span>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
