<% content_for :title, "Search" %>
<h1 class="title">Search</h1>

<%= form_with url: search_path, method: :get, data: { turbo_frame: "_top" } do |form| %>
  <div class="field has-addons">
    <div class="control is-expanded">
      <%= form.search_field :q, value: @query, placeholder: "Search items…",
            class: "input", autofocus: true %>
    </div>
    <div class="control">
      <%= form.submit "Search", class: "button is-primary" %>
    </div>
  </div>
<% end %>

<% if @query.blank? %>
  <p class="has-text-weak mt-4">Enter a search term to find items by title.</p>
<% elsif @items.empty? %>
  <p class="has-text-weak mt-4">No items match &ldquo;<%= @query %>&rdquo;.</p>
<% else %>
  <p class="has-text-weak mt-4">
    <%= pluralize(@items.size, "item") %> matching &ldquo;<%= @query %>&rdquo;.
  </p>

  <div class="table-container">
    <table class="table is-fullwidth is-striped is-hoverable">
      <thead>
        <tr><th>Title</th><th>Project</th><th>Type</th><th>Status</th><th>Points</th><th>Tags</th></tr>
      </thead>
      <tbody>
        <% @items.each do |item| %>
          <tr>
            <td><%= link_to item.title, project_item_path(item.project, item) %></td>
            <td><%= link_to item.project.name, project_path(item.project) %></td>
            <td><%= item.item_type %></td>
            <td><%= item.status.name %></td>
            <td><%= item.points %></td>
            <td>
              <div class="tags">
                <% item.tags.each do |tag| %>
                  <span class="tag is-small"><%= tag.name %></span>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
