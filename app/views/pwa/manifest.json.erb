<%# Home-screen icon mirrors the favicon split: green P in dev, terracotta P in prod.
    The PNGs are opaque, full-square (bin/generate_favicons) so maskable is safe. %>
<% suffix = Rails.env.production? ? "" : "-dev" %>
<% icon_svg = "/icon#{suffix}.svg" %>
{
  "name": "Project Tracker",
  "short_name": "Tracker",
  "description": "Personal project and item tracker.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "theme_color": "#a1462b",
  "background_color": "#f8f5f2",
  "icons": [
    {
      "src": "<%= icon_svg %>",
      "type": "image/svg+xml",
      "sizes": "any",
      "purpose": "any"
    },
    {
      "src": "/icon-192<%= suffix %>.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any"
    },
    {
      "src": "/icon-512<%= suffix %>.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any"
    },
    {
      "src": "/icon-512<%= suffix %>.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }
  ]
}
