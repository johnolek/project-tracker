<%# Home-screen icon mirrors the favicon split: green P in dev, terracotta P in prod. %>
<% icon_svg = Rails.env.production? ? "/icon.svg" : "/icon-dev.svg" %>
{
  "name": "Project Tracker",
  "short_name": "Tracker",
  "description": "Personal project and item tracker.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "theme_color": "#a1462b",
  "background_color": "#f8f5f2",
  "icons": [
    {
      "src": "<%= icon_svg %>",
      "type": "image/svg+xml",
      "sizes": "any",
      "purpose": "any"
    },
    {
      "src": "<%= icon_svg %>",
      "type": "image/svg+xml",
      "sizes": "any",
      "purpose": "maskable"
    },
    {
      "src": "/icon.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any"
    },
    {
      "src": "/icon.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }
  ]
}
