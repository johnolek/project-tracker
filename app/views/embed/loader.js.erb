// Embeddable feedback widget loader (PROJ-89). A host page includes this with
// a single async <script src=".../embed.js"> tag. It injects a fixed iframe
// pointing at the tracker's /embed/frame, kept invisible until the frame
// reports a size — so a non-allowlisted host (frame 404s, never posts) shows
// nothing at all. All framing/sizing is driven by postMessage; the loader
// forwards fresh page context so the form can attach the current URL/viewport.
(function () {
  var script = document.currentScript;
  if (!script) return;

  var trackerOrigin = new URL(script.src).origin;
  var frameSrc = trackerOrigin + "<%= embed_frame_path %>?origin=" +
    encodeURIComponent(location.origin);

  var iframe = document.createElement("iframe");
  iframe.src = frameSrc;
  iframe.title = "Feedback";
  iframe.setAttribute("allow", "display-capture");
  iframe.style.cssText = [
    "position:fixed",
    "top:50%",
    "transform:translateY(-50%)",
    "right:0",
    "width:0",
    "height:0",
    "border:0",
    "z-index:2147483647",
    "background:transparent",
    "color-scheme:normal",
    "overflow:hidden"
  ].join(";");

  function sendContext() {
    if (!iframe.contentWindow) return;
    iframe.contentWindow.postMessage({
      type: "pt-embed:context",
      url: location.href,
      viewport: { width: window.innerWidth, height: window.innerHeight }
    }, trackerOrigin);
  }

  iframe.addEventListener("load", sendContext);
  window.addEventListener("resize", sendContext);

  // Hidden for the current page view only (per-page-view semantics). Kept off
  // any storage: the next page view (turbo:load) or a full reload clears it.
  var hidden = false;

  function onMessage(event) {
    if (event.origin !== trackerOrigin) return;
    var data = event.data || {};
    if (data.type === "pt-embed:size") {
      iframe.style.width = Math.max(0, data.width) + "px";
      iframe.style.height = Math.max(0, data.height) + "px";
    } else if (data.type === "pt-embed:hide") {
      // Dismiss for this page view only. Keep the listeners so the next
      // turbo:load can bring the widget back; a full reload re-runs this
      // whole script fresh, which also restores it.
      hidden = true;
      iframe.style.display = "none";
    }
  }

  window.addEventListener("message", onMessage);

  function inject() {
    document.body.appendChild(iframe);
  }

  // Turbo Drive replaces <body> on navigation, tearing the iframe out of the
  // document (and the head script never re-runs). Re-append it on every
  // turbo:load so the widget survives client-side navigation, and treat each
  // navigation as a new page view — clearing any per-page-view dismissal.
  // Fires on the initial load too, where the iframe is still connected and
  // this is a no-op; never fires in non-Turbo hosts (harmless there).
  function onTurboLoad() {
    if (hidden) {
      hidden = false;
      iframe.style.display = "";
    }
    if (!iframe.isConnected && document.body) inject();
  }
  document.addEventListener("turbo:load", onTurboLoad);

  if (document.body) {
    inject();
  } else {
    document.addEventListener("DOMContentLoaded", inject);
  }
})();
