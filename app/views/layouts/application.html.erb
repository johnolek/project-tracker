<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Project Tracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Project Tracker">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Installable PWA manifest (routes enabled in config/routes.rb). %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%# Terracotta browser UI in light, dark-scheme sand in dark, matching the theme. %>
    <meta name="theme-color" content="#a1462b">
    <meta name="theme-color" content="#1d1711" media="(prefers-color-scheme: dark)">

    <%# Green P locally, terracotta P in production, so tabs are unmistakable.
        SVG for modern browsers, favicon.ico as the legacy/auto-requested fallback,
        and an opaque 180×180 apple-touch-icon (square corners; iOS masks its own). %>
    <link rel="icon" href="<%= Rails.env.production? ? "/icon.svg" : "/icon-dev.svg" %>" type="image/svg+xml">
    <link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48">
    <link rel="apple-touch-icon" href="<%= Rails.env.production? ? "/apple-touch-icon.png" : "/apple-touch-icon-dev.png" %>">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <nav class="navbar" role="navigation" aria-label="main navigation">
      <div class="container">
        <div class="navbar-brand">
          <%= link_to "Project Tracker", root_path, class: "navbar-item has-text-weight-bold" %>
          <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false">
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
          </a>
        </div>

        <div class="navbar-menu">
          <div class="navbar-end">
            <% if signed_in? %>
              <div class="navbar-item">
                <%= form_with url: search_path, method: :get, data: { turbo_frame: "_top" } do |form| %>
                  <div class="field has-addons mb-0">
                    <div class="control">
                      <%= form.search_field :q, value: params[:q], placeholder: "Search…",
                            class: "input is-small", "aria-label": "Search projects and items" %>
                    </div>
                    <div class="control">
                      <%= form.submit "Search", class: "button is-small" %>
                    </div>
                  </div>
                <% end %>
              </div>
              <%= link_to "Projects", projects_path, class: "navbar-item" %>
              <div class="navbar-item has-dropdown is-hoverable">
                <a class="navbar-link" role="button" tabindex="0"
                   aria-haspopup="true" aria-expanded="false"><%= current_user.username %></a>
                <div class="navbar-dropdown is-right">
                  <%= link_to "Account", edit_settings_account_path, class: "navbar-item" %>
                  <%= link_to "Statuses", settings_statuses_path, class: "navbar-item" %>
                  <%= link_to "Item types", settings_item_types_path, class: "navbar-item" %>
                  <%= link_to "Passkeys", settings_credentials_path, class: "navbar-item" %>
                  <%= link_to "API keys", settings_api_keys_path, class: "navbar-item" %>
                  <%= link_to "Admin", edit_settings_admin_path, class: "navbar-item" %>
                  <hr class="navbar-divider">
                  <%= button_to "Sign out", logout_path, method: :delete, class: "navbar-item",
                        form: { data: { turbo: false } } %>
                </div>
              </div>
            <% else %>
              <%= link_to "Sign in", login_path, class: "navbar-item" %>
              <div class="navbar-item">
                <% if AppSetting.signups_open? %>
                  <%= link_to "Register", signup_path, class: "button is-primary is-small" %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <main class="section">
      <div class="container">
        <% if signed_in? && current_user.email.blank? %>
          <div class="notification is-warning">
            Add a recovery email so you can always get back in — even without your passkey.
            <%= link_to "Add email", edit_settings_account_path, class: "has-text-weight-semibold" %>
          </div>
        <% elsif signed_in? && !current_user.email_verified? %>
          <div class="notification is-warning">
            Verify your email (<strong><%= current_user.email %></strong>) to use it for sign-in and recovery.
            <%= button_to "Resend link", email_verification_request_path, method: :post,
                  class: "button is-small is-warning is-inverted ml-2", form: { class: "is-inline" } %>
          </div>
        <% end %>
        <%= yield %>
      </div>
    </main>

    <%# Flash surfaces as dismissible toasts in a fixed overlay (never pushes page
        content down). Always mounted so client-raised "toast" events land too. %>
    <div data-svelte-component="Toasts" data-props="<%= toast_props(flash).to_json %>"></div>
  </body>
</html>
