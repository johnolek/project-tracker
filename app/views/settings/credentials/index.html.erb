<% content_for :title, "Passkeys" %>
<h1 class="title">Passkeys</h1>
<p class="subtitle is-6 has-text-weak">
  Sign-in keys for your account. Add one for each device so a lost device never locks you out.
</p>

<form data-passkey="add-credential"
      data-options-url="<%= options_settings_credentials_path %>"
      data-callback-url="<%= settings_credentials_path %>">
  <div class="field is-grouped is-align-items-flex-end">
    <div class="control">
      <label class="label" for="passkey-nickname">Name (optional)</label>
      <input id="passkey-nickname" name="nickname" class="input" placeholder="e.g. Work laptop" autocomplete="off">
    </div>
    <div class="control">
      <button type="submit" class="button is-primary">Add passkey</button>
    </div>
  </div>
  <p class="help has-text-danger" data-passkey-error></p>
</form>

<% if @credentials.any? %>
  <table class="table is-fullwidth">
    <thead>
      <tr>
        <th>Name</th>
        <th>Added</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @credentials.each do |credential| %>
        <tr>
          <td><%= credential.nickname.presence || "Passkey" %></td>
          <td><%= credential.created_at.to_date.to_fs(:long) %></td>
          <td class="has-text-right">
            <% if @credentials.size > 1 %>
              <%= button_to "Remove", settings_credential_path(credential), method: :delete,
                    class: "button is-danger is-light is-small",
                    form: { data: { turbo_confirm: "Remove the \"#{credential.nickname.presence || "Passkey"}\" passkey?" } } %>
            <% else %>
              <span class="has-text-weak is-size-7" title="Add another passkey before removing this one">Only passkey</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
