<div class="container">
  <h1 class="title">Admin</h1>

  <div class="box">
    <%= form_with url: settings_admin_path, method: :patch, scope: :app_setting do |form| %>
      <div class="field">
        <%= form.label :allow_signups, "New account sign-ups", class: "label" %>
        <div class="control">
          <div class="select">
            <%= form.select :allow_signups,
                  options_for_select(
                    [ [ "Automatic — open only while no accounts exist", "auto" ],
                      [ "Open", "true" ],
                      [ "Closed", "false" ] ],
                    selected: @setting.allow_signups.nil? ? "auto" : @setting.allow_signups.to_s
                  ) %>
          </div>
        </div>
        <p class="help">
          Currently <strong><%= AppSetting.signups_open? ? "open" : "closed" %></strong>.
          Automatic keeps sign-ups closed once an account exists (development stays open).
        </p>
      </div>
      <div class="field">
        <%= form.submit "Save", class: "button is-primary" %>
      </div>
    <% end %>
  </div>

  <div class="box">
    <h2 class="title is-5">Email deliveries</h2>
    <% if @failed_emails.any? %>
      <table class="table is-fullwidth">
        <thead>
          <tr><th>Mail</th><th>Error</th><th>Failed</th><th></th></tr>
        </thead>
        <tbody>
          <% @failed_emails.each do |failed| %>
            <tr>
              <td><code><%= failed.mailer %>#<%= failed.action %></code></td>
              <td class="failed-email-error"><%= failed.message %></td>
              <td><%= time_ago_in_words(failed.failed_at) %> ago</td>
              <td>
                <%= button_to "Retry", retry_failed_email_settings_admin_path(failed_execution_id: failed.failed_execution_id),
                      method: :post, class: "button is-small", form: { class: "is-inline" } %>
                <%= button_to "Dismiss", failed_email_settings_admin_path(failed_execution_id: failed.failed_execution_id),
                      method: :delete, class: "button is-small is-light", form: { class: "is-inline" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="has-text-weak">No failed deliveries.</p>
    <% end %>
  </div>
</div>
