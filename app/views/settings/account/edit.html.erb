<% content_for :title, "Account" %>
<h1 class="title">Account</h1>
<p class="subtitle is-6 has-text-weak">Your username and the email used for email sign-in and recovery.</p>

<%= form_with model: @user, url: settings_account_path, method: :patch do |form| %>
  <% if @user.errors.any? %>
    <div class="notification is-danger is-light">
      <ul>
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :username, class: "label" %>
    <div class="control">
      <%= form.text_field :username, class: "input", disabled: true %>
    </div>
  </div>

  <div class="field">
    <%= form.label :email, class: "label" %>
    <div class="control">
      <%= form.email_field :email, class: "input", autocomplete: "email" %>
    </div>
    <p class="help">Used for the email sign-in link and to recover access if a passkey isn't available (e.g. a lost device or a domain change).</p>
  </div>

  <div class="field">
    <%= form.submit "Save", class: "button is-primary" %>
  </div>
<% end %>
