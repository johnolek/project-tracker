<%= form_with model: project do |form| %>
  <% if project.errors.any? %>
    <div class="notification is-danger is-light">
      <ul>
        <% project.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :name, class: "label" %>
    <div class="control">
      <%= form.text_field :name, class: "input", autofocus: project.new_record? %>
    </div>
  </div>

  <% slug_frozen = project.persisted? && project.items.exists? %>
  <div class="field">
    <%= form.label :slug, class: "label" %>
    <div class="control">
      <%= form.text_field :slug, class: "input", disabled: slug_frozen,
            placeholder: "Derived from the name when left blank" %>
    </div>
    <p class="help">
      <% if slug_frozen %>
        Locked — the project has items, so keys like <%= project.slug %>-1 must stay stable.
      <% else %>
        Prefixes item keys (e.g. <%= project.slug.presence || "PROJ" %>-1). Uppercase letters and digits, changeable until the project has items.
      <% end %>
    </p>
  </div>

  <div class="field">
    <%= form.submit class: "button is-primary" %>
  </div>
<% end %>
