<%= form_with model: project do |form| %>
  <% if project.errors.any? %>
    <div class="notification is-danger is-light">
      <ul>
        <% project.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :name, class: "label" %>
    <div class="control">
      <%= form.text_field :name, class: "input", autofocus: project.new_record? %>
    </div>
  </div>

  <div class="field">
    <%= form.label :slug, class: "label" %>
    <div class="control">
      <%= form.text_field :slug, class: "input",
            placeholder: "Derived from the name when left blank" %>
    </div>
    <p class="help">
      Prefixes item keys (e.g. <%= project.slug.presence || "PROJ" %>-1). Uppercase letters and digits.
      <% if project.persisted? && project.items.exists? %>
        Changing it renames every key (<%= project.slug %>-1 → NEW-1); the old slug is reserved and old links redirect.
      <% end %>
    </p>
  </div>

  <div class="field">
    <%= form.submit class: "button is-primary" %>
  </div>
<% end %>
