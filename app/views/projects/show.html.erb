<% content_for :title, @project.name %>
<div class="level is-mobile">
  <div class="level-left"><h1 class="title"><%= @project.name %></h1></div>
  <div class="level-right">
    <div class="buttons">
      <%= link_to "Edit", edit_project_path(@project), class: "button" %>
      <%= button_to "Delete", @project, method: :delete, class: "button is-danger is-outlined",
            form: { data: { turbo_confirm: "Delete this project?" } } %>
    </div>
  </div>
</div>

<h2 class="title is-4">Board (live)</h2>
<%= turbo_stream_from @project, "items" %>
<%= render "items/board", project: @project %>

<div class="level is-mobile mt-5">
  <div class="level-left"><h2 class="title is-4">Manage items</h2></div>
  <div class="level-right"><%= link_to "New item", new_project_item_path(@project), class: "button is-primary" %></div>
</div>

<% if @items.any? %>
  <div class="table-container">
    <table class="table is-fullwidth is-striped is-hoverable">
      <thead>
        <tr><th>Title</th><th>Type</th><th>Status</th><th>Points</th><th>Tags</th></tr>
      </thead>
      <tbody>
        <% @items.each do |item| %>
          <tr>
            <td><%= link_to item.title, project_item_path(@project, item) %></td>
            <td><%= item.item_type %></td>
            <td><%= item.status.name %></td>
            <td><%= item.points %></td>
            <td>
              <div class="tags">
                <% item.tags.each do |tag| %>
                  <span class="tag is-small"><%= tag.name %></span>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="has-text-weak">No items yet.</p>
<% end %>

<p class="mt-4"><%= link_to "Back to projects", projects_path %></p>
