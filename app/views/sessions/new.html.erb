<% content_for :title, "Sign in" %>
<h1>Sign in</h1>
<p>Sign in with the passkey you registered on this device.</p>

<%= form_with url: login_path, method: :post,
      data: { passkey: "authenticate", options_url: login_options_path, callback_url: login_path, turbo: false } do |form| %>
  <div>
    <%= form.label :username %>
    <%= form.text_field :username, autocomplete: "username webauthn", required: true %>
  </div>

  <p data-passkey-error class="passkey-error"></p>

  <%= form.submit "Sign in with a passkey" %>
<% end %>

<p><%= link_to "Need an account? Register", signup_path %></p>
