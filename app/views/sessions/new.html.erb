<% content_for :title, "Sign in" %>
<div class="columns is-centered">
  <div class="column is-half-tablet is-one-third-widescreen">
    <h1 class="title">Sign in</h1>
    <p class="subtitle is-6">Sign in with a passkey — your device will offer the one you registered. No username needed.</p>

    <div class="box">
      <%= form_with url: login_path, method: :post,
            data: { passkey: "authenticate", options_url: login_options_path, callback_url: login_path, turbo: false } do |form| %>
        <p data-passkey-error class="help is-danger"></p>

        <div class="field">
          <%= form.submit "Sign in with a passkey", class: "button is-primary is-fullwidth" %>
        </div>
      <% end %>
    </div>

    <div class="is-flex is-align-items-center my-4">
      <hr class="is-flex-grow-1 my-0">
      <span class="mx-3 has-text-weak is-size-7">or</span>
      <hr class="is-flex-grow-1 my-0">
    </div>

    <div class="box">
      <%= form_with url: email_sign_in_request_path, method: :post do |form| %>
        <div class="field">
          <%= form.label :email, "Email", class: "label" %>
          <div class="control">
            <%= form.email_field :email, class: "input", autocomplete: "email", required: true, placeholder: "you@example.com" %>
          </div>
        </div>
        <div class="field">
          <%= form.submit "Email me a sign-in link", class: "button is-fullwidth" %>
        </div>
      <% end %>
      <p class="help">A one-tap link, valid 20 minutes. Works on any device — handy if your passkey isn't available here.</p>
    </div>

    <% if Rails.configuration.x.allow_signups %>
      <p><%= link_to "Need an account? Register", signup_path %></p>
    <% end %>
  </div>
</div>
